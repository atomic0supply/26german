rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAppUser() {
      return isSignedIn()
        && userDoc().data.active == true
        && (
          userDoc().data.role == 'technician'
          || userDoc().data.role == 'admin'
          || userDoc().data.role == 'office'
        );
    }

    function isAdmin() {
      return isSignedIn()
        && userDoc().data.active == true
        && userDoc().data.role == 'admin';
    }

    function isOfficeOrAdmin() {
      return isSignedIn()
        && userDoc().data.active == true
        && (
          userDoc().data.role == 'office'
          || userDoc().data.role == 'admin'
        );
    }

    function reportDoc(reportId) {
      return get(/databases/$(database)/documents/reports/$(reportId));
    }

    function ownsReport(reportId) {
      return isSignedIn() && reportDoc(reportId).data.createdBy == request.auth.uid;
    }

    function reportIsDraft(reportId) {
      return reportDoc(reportId).data.status == 'draft';
    }

    function clientDoc(clientId) {
      return get(/databases/$(database)/documents/clients/$(clientId));
    }

    function ownsClient(clientId) {
      return isSignedIn() && clientDoc(clientId).data.createdBy == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      allow create, update, delete: if false;
    }

    match /clients/{clientId} {
      allow read: if isAppUser()
        && (resource.data.createdBy == request.auth.uid || isOfficeOrAdmin());
      allow create: if isAppUser() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAppUser()
        && (ownsClient(clientId) || isOfficeOrAdmin())
        && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if isAppUser() && (ownsClient(clientId) || isOfficeOrAdmin());
    }

    match /reports/{reportId} {
      allow create: if isAppUser()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == 'draft';

      // Single document read
      allow get: if isAppUser()
        && (resource.data.createdBy == request.auth.uid || isOfficeOrAdmin());

      // Collection query: admin/office get blanket allow; technicians must query with where("createdBy","==",uid)
      allow list: if isOfficeOrAdmin()
        || (isAppUser() && resource.data.createdBy == request.auth.uid);

      allow update: if isAppUser()
        && resource.data.createdBy == request.auth.uid
        && resource.data.status == 'draft'
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.status == 'draft';

      allow delete: if isAppUser()
        && (resource.data.createdBy == request.auth.uid || isOfficeOrAdmin())
        && resource.data.status == 'draft';

      match /photos/{photoId} {
        allow get: if isAppUser() && (ownsReport(reportId) || isOfficeOrAdmin());
        allow list: if isOfficeOrAdmin() || (isAppUser() && ownsReport(reportId));
        allow create, update: if isAppUser() && ownsReport(reportId) && reportIsDraft(reportId);
        allow delete: if false;
      }
    }

    match /config/{docId} {
      allow read, write: if isAdmin();
    }

    // Partners / Firmen colaboradoras: lectura para cualquier técnico autenticado
    // (necesario para el selector en el informe); escritura solo office/admin.
    match /partners/{partnerId} {
      allow read: if isAppUser();
      allow create, update, delete: if isOfficeOrAdmin();
    }

    match /templates/{templateId} {
      allow read: if isAppUser() && (resource.data.status == 'published' || isAdmin());
      allow create, update, delete: if isAdmin();

      match /versions/{versionId} {
        allow read: if isAppUser() && (resource.data.status == 'published' || isAdmin());
        allow create, update, delete: if isAdmin();
      }
    }
  }
}
