rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isTechnician() {
      return isSignedIn()
        && userDoc().data.role == 'technician'
        && userDoc().data.active == true;
    }

    function reportDoc(reportId) {
      return get(/databases/$(database)/documents/reports/$(reportId));
    }

    function ownsReport(reportId) {
      return isSignedIn() && reportDoc(reportId).data.createdBy == request.auth.uid;
    }

    function reportIsDraft(reportId) {
      return reportDoc(reportId).data.status == 'draft';
    }

    function clientDoc(clientId) {
      return get(/databases/$(database)/documents/clients/$(clientId));
    }

    function ownsClient(clientId) {
      return isSignedIn() && clientDoc(clientId).data.createdBy == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /templates/{templateId} {
      allow read: if isTechnician();
      allow create, update, delete: if false;
    }

    match /clients/{clientId} {
      allow read: if isTechnician() && resource.data.createdBy == request.auth.uid;
      allow create: if isTechnician() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isTechnician()
        && ownsClient(clientId)
        && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if isTechnician() && ownsClient(clientId);
    }

    match /reports/{reportId} {
      allow create: if isTechnician()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == 'draft';

      allow read: if isTechnician() && resource.data.createdBy == request.auth.uid;

      allow update: if isTechnician()
        && resource.data.createdBy == request.auth.uid
        && resource.data.status == 'draft'
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.status == 'draft';

      allow delete: if isTechnician()
        && resource.data.createdBy == request.auth.uid
        && resource.data.status == 'draft';

      match /photos/{photoId} {
        allow read: if isTechnician() && ownsReport(reportId);
        allow create, update: if isTechnician() && ownsReport(reportId) && reportIsDraft(reportId);
        allow delete: if false;
      }
    }
  }
}
