rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isTechnician() {
      return isSignedIn()
        && userDoc().data.role == 'technician'
        && userDoc().data.active == true;
    }

    function isAppUser() {
      return isSignedIn()
        && userDoc().data.active == true
        && (
          userDoc().data.role == 'technician'
          || userDoc().data.role == 'admin'
          || userDoc().data.role == 'office'
        );
    }

    function isTemplateAdmin() {
      return isSignedIn()
        && userDoc().data.active == true
        && (userDoc().data.role == 'admin' || userDoc().data.role == 'office');
    }

    function reportDoc(reportId) {
      return get(/databases/$(database)/documents/reports/$(reportId));
    }

    function ownsReport(reportId) {
      return isSignedIn() && reportDoc(reportId).data.createdBy == request.auth.uid;
    }

    function reportIsDraft(reportId) {
      return reportDoc(reportId).data.status == 'draft';
    }

    function clientDoc(clientId) {
      return get(/databases/$(database)/documents/clients/$(clientId));
    }

    function ownsClient(clientId) {
      return isSignedIn() && clientDoc(clientId).data.createdBy == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (userId == request.auth.uid || isTemplateAdmin());
      allow list: if isTemplateAdmin();
      allow create, update, delete: if false;
    }

    match /insurers/{insurerId} {
      allow read: if isAppUser();
      allow write: if isTemplateAdmin();
    }

    match /company/{docId} {
      allow read: if isAppUser();
      allow write: if isTemplateAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if isAppUser() && (
        resource.data.assignedTo == request.auth.uid || isTemplateAdmin()
      );
      allow create: if isTemplateAdmin()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isTemplateAdmin()
        || (isTechnician()
            && resource.data.assignedTo == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "updatedAt"]));
      allow delete: if isTemplateAdmin();
    }

    match /fcmTokens/{tokenId} {
      allow create, update: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow read, delete: if false;
    }

    match /templates/{templateId} {
      allow read: if isTechnician() || isTemplateAdmin();
      allow create: if isTemplateAdmin() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isTemplateAdmin() && resource.data.createdBy == request.auth.uid;
      allow delete: if false;

      match /versions/{versionId} {
        allow read: if isTechnician() || isTemplateAdmin();
        allow create: if isTemplateAdmin() && request.resource.data.createdBy == request.auth.uid;
        allow update: if isTemplateAdmin() && resource.data.createdBy == request.auth.uid;
        allow delete: if false;
      }
    }

    match /clients/{clientId} {
      allow read: if isAppUser() && (resource.data.createdBy == request.auth.uid || isTemplateAdmin());
      allow list: if isTemplateAdmin();
      allow create: if isAppUser() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAppUser()
        && ownsClient(clientId)
        && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if isAppUser() && ownsClient(clientId);
    }

    match /reports/{reportId} {
      allow create: if isAppUser()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == 'draft';

      allow read: if isAppUser() && resource.data.createdBy == request.auth.uid;

      allow update: if isAppUser()
        && resource.data.createdBy == request.auth.uid
        && resource.data.status == 'draft'
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.status == 'draft';

      allow delete: if isAppUser()
        && resource.data.createdBy == request.auth.uid
        && resource.data.status == 'draft';

      match /photos/{photoId} {
        allow read: if isAppUser() && ownsReport(reportId);
        allow create, update: if isAppUser() && ownsReport(reportId) && reportIsDraft(reportId);
        allow delete: if false;
      }
    }
  }
}
